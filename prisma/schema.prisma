// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ReglaPersonalizada {
  id               String   @id @default(cuid())
  shop             String
  nombre           String
  minAncho         Int
  maxAncho         Int
  minAlto          Int
  maxAlto          Int
  precioPorM2      Float
  waterproofActivo Boolean  @default(true)
  waterproofPorM2  Float    @default(0)
  activa           Boolean  @default(true)
  productIds       String[] @default([])
  createdAt        DateTime @default(now())
}

model PedidoCustom {
  id           String   @id @default(cuid())
  shop         String
  orderId      String
  ancho        Int
  alto         Int
  waterproof   Boolean  @default(false)
  precioTotal  Float
  estado       String   @default("pendiente")
  productTitle String   @default("")
  tipo         String   @default("medida")
  createdAt    DateTime @default(now())
}

model ReglaImpermeabilizador {
  id           String                      @id @default(cuid())
  shop         String
  productId    String
  productTitle String                      @default("")
  activa       Boolean                     @default(true)
  createdAt    DateTime                    @default(now())
  variantes    VarianteImpermeabilizador[]

  @@unique([shop, productId])
}

model VarianteImpermeabilizador {
  id           String                 @id @default(cuid())
  reglaId      String
  regla        ReglaImpermeabilizador @relation(fields: [reglaId], references: [id], onDelete: Cascade)
  variantId    String
  variantTitle String                 @default("")
  precio       Float
  aplica       Boolean                @default(true)

  @@unique([reglaId, variantId])
}

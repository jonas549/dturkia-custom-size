// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ReglaPersonalizada {
  id               String   @id @default(cuid())
  shop             String
  nombre           String
  minAncho         Int
  maxAncho         Int
  minAlto          Int
  maxAlto          Int
  precioPorCm2     Float
  waterproofActivo Boolean  @default(true)
  waterproofPorCm2 Float    @default(0)
  activa           Boolean  @default(true)
  productIds       String[] @default([])
  createdAt        DateTime @default(now())
}

model PedidoCustom {
  id          String   @id @default(cuid())
  shop        String
  orderId     String
  ancho       Int
  alto        Int
  waterproof  Boolean  @default(false)
  precioTotal Float
  createdAt   DateTime @default(now())
}
